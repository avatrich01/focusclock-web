# ── Supabase (Settings → API). Public — protected by Row Level Security. ──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-anon-public-key

# ── Web Push (optional — enables notifications when the tab is closed) ──
# Generate the key pair with:  npm run gen-vapid
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Service-role key (Settings → API → service_role). SERVER ONLY — never expose
# to the browser / never prefix with NEXT_PUBLIC. Used by the cron route to read
# all users and send pushes.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret the cron caller must pass (?secret=... or x-cron-secret header).
CRON_SECRET=change-me-to-a-long-random-string
